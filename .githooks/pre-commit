#!/usr/bin/env bash
# Git pre-commit hook for forked-evm-testing.
#
# To activate (one-time per clone):
#     git config core.hooksPath .githooks
#
# Currently runs:
# - scripts/check-dashboard-sync.py — fails the commit if the inline
#   Grafana dashboard JSON in docker-compose.yml drifts from the
#   standalone monitoring/grafana/dashboards/api-perf.json.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
exec python scripts/check-dashboard-sync.py
