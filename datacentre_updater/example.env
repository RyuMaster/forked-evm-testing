# .env
# Source MySQL Database
SOURCE_DB_HOST=xxxxx
SOURCE_DB_USER=xxxxx
SOURCE_DB_PASSWORD=xxxxx
SOURCE_DB_NAME=xxxxx

# Destination MySQL Database
DEST_DB_HOST=xxxxx
DEST_DB_USER=xxxxx
DEST_DB_PASSWORD=xxxxx
DEST_DB_NAME=xxxxx

# SQLite Database Path
SQLITE_PATH=sqlite/storage.sqlite

# url for default datapack
DATAPACK_URL=https://downloads.soccerverse.com/svpack/default.json

# Output folder for data dumps (share_orders CSV/JSON, leagues JSON, league tables JSON).
# Leave unset or empty to disable the data dump updater.
# DUMP_OUTPUT_FOLDER=/var/data/dumps

# The Game ID to use for activity filtering.  sv for production,
# svt for test.
GAME_ID=sv

# Big_query
BIGQUERY_DB_HOST=xxx
BIGQUERY_DB_USER=xxx
BIGQUERY_DB_PASSWORD=xxx
BIGQUERY_DB_NAME=xxx

# Subgraph for democrit-sv
SVC_POLYGON_SUBGRAPH_URL=https://graph.soccerverse.com/subgraphs/id/QmahYLjXXeQajGieM1bqFgtgWCsGfsML8Na2Drratweq5f
# xaya-stats
POLYGON_STATS_SUBGRAPH_URL=https://graph.soccerverse.com/subgraphs/id/QmTTSBqcXtH9en4FMueKF8Z54KHJPrivMztFKMjtMPbPUx
# sv-subgraph
SV_SUBGRAPH_URL=https://graph.soccerverse.com/subgraphs/id/Qma2f18fCehujQ9Vx7s8Gb3sGjNfu238R2NhUBLbMSX8E7
