# The endpoint that should be used for the underlying blockchain network
# that will be forked.  This must be an archival node.
# Reuse the same node the Soccerverse stack uses.
BLOCKCHAIN_ENDPOINT="https://polygon-node.xaya.io"

# The block number at which to fork the network.  This can either be an actual
# block number or "latest".
FORK_BLOCK_NUMBER="latest"

# The contract address for the XayaAccounts contract to be used for
# tracking moves.  The default value is the official contract
# on Polygon mainnet (shared by all Xaya games, incl. Taurion g/tn).
ACCOUNTS_CONTRACT="0x8C12253F71091b9582908C8a44F78870Ec6F304F"

# The Docker image to run for the Taurion GSP.  This is the locally-loaded
# Taurion image on the laptop; the compose runs its `tauriond` binary.
GSP_IMAGE="tn-base:latest"

# Host port for this stack's nginx.  MUST differ from the Soccerverse stack
# (which publishes 8100). Default 8101.
TAURION_NGINX_PORT=8101
