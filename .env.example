# The JSON-RPC endpoint URL for the Polygon (or other EVM) network.
# This is used both by nginx (for /chain) and by graph-node for indexing.
BLOCKCHAIN_RPC_URL=""

# Authorization header value sent to the blockchain RPC endpoint.
BLOCKCHAIN_AUTH_HEADER=""

# The contract address for the XayaAccounts contract to be used for
# tracking moves.  The default value is the official contract
# on Polygon mainnet.
ACCOUNTS_CONTRACT="0x8C12253F71091b9582908C8a44F78870Ec6F304F"

# The Docker image to run for the GSP.  If custom options or variables
# are required for the GSP, this must already be contained in this container
# via an entrypoint.  Only standard arguments (such as Xaya RPC URL) will
# be passed to it.
GSP_IMAGE=""

# Pre-built image for datacentre-api. Built from upstream repo at
# C:\WorkFiles\datacentre_api (not vendored here). See CLAUDE.md "Building
# images" for the build commands.
DATACENTRE_API_IMAGE=""

# Pre-built image for datacentre-updater. Built from upstream repo at
# C:\WorkFiles\datacentre_updater. The compose entrypoint applies the
# utf8mb4 collation sed patch at runtime as a fallback.
DATACENTRE_UPDATER_IMAGE=""

# Pre-built image for subgraph-deploy (one-shot graph-cli deployer).
# Built from ./subgraph-deploy in this repo.
SUBGRAPH_DEPLOY_IMAGE=""

# Game ID to use for activity and user tracking (sv for production, svt for test).
GAME_ID="sv"

# Path to the pre-synced GSP SQLite database file.
STORAGE_SQLITE_PATH="./storage.sqlite"

# Force gsp-init to overwrite the seeded SQLite file in the gspdata volume
# even when one already exists. Set to 1 when you want a fresh snapshot to
# replace stale state from a previous deploy without manually wiping the
# volume; flip back to 0 for normal runs. Requires recreating the gsp
# container so it actually re-reads the new file:
#   FORCE_RESEED=1 docker compose up -d --force-recreate gsp-init gsp
FORCE_RESEED=0

# Path to the archival MySQL dump to import on first start.
ARCHIVAL_SQL_PATH="./archival.sql"

# Path to the userconfig MySQL dump to import on first start.
USERCONFIG_SQL_PATH="./userconfig.sql"

# Host port for MariaDB external access (default: 3307 to avoid conflicts).
MARIADB_PORT="3307"

# Host port for Redis external access (default: 6380 — the conventional
# "alt redis" port, chosen to avoid collisions with any other redis already
# running on the host). The container still listens on 6379 internally;
# this is just the host-side mapping. Published so a frontend running
# outside the Docker network (e.g. a local load-test driver on another host
# on the LAN) can reuse this Redis as its server-side cache. Redis has no
# auth by default; treat the LAN as trusted.
REDIS_PORT="6380"

# ---- Democrit subgraph configuration ----
# All four DEMOCRIT_* vars below are needed to enable democrit indexing.
# If any are unset, subgraph-deploy skips democrit (the rest of the stack
# still boots cleanly). See subgraphs/democrit/POPULATE_ABIS.md.

# 1. Real democrit ABI files (forge build artefacts on the deploy host).
#    Generate via `forge build` in the democrit-evm repo, then point these
#    vars at the resulting JSON files (absolute paths required).
# DEMOCRIT_ABI_PATH="/path/to/democrit-evm/out/Democrit.sol/Democrit.json"
# VAULTMANAGER_ABI_PATH="/path/to/democrit-evm/out/VaultManager.sol/VaultManager.json"

# 2. Network name. Must match graph-node's chain config in docker-compose.yml
#    (currently hardcoded as `matic` = Polygon mainnet).
DEMOCRIT_NETWORK="matic"

# 3. Deployed Democrit + VaultManager contract addresses on the chain above.
# DEMOCRIT_CONTRACT_ADDRESS=""
# VAULTMANAGER_CONTRACT_ADDRESS=""

# 4. Block number to start indexing from. Use the deployment block of the
#    Democrit contract — earlier values waste indexer time.
# DEMOCRIT_START_BLOCK="0"

# --- MariaDB credentials (used by the Grafana datasource) -------------------
# The mariadb service in docker-compose.yml seeds with MARIADB_ROOT_PASSWORD=
# gsparchival hardcoded. The Grafana datasource provisioning needs login
# creds to query api_request_log, so set these to match the running DB.
# Default values match the hardcoded compose seed — change both places if
# you ever rotate the root password.
MARIADB_USER=root
MARIADB_PASSWORD=gsparchival

# --- Perf beacon (datacentre-api /perf/beacon) ------------------------------
# Comma-separated allowlist of Origin headers permitted to POST telemetry.
# The beacon endpoint has its own custom CORS middleware that 403s any
# request whose Origin is NOT in this list — empty means no browser will
# ever succeed. Add every domain that runs the recorder-enabled frontend.
PERF_BEACON_ALLOWED_ORIGINS=http://localhost:3000

# Per-IP rate limit for /perf/beacon. Default 20000/minute is generous
# enough for the 250-context Playwright load test (all from one source IP)
# without tripping. Lower for production once realistic.
PERF_BEACON_RATE=20000/minute

# --- Monitoring (Plan 2) -----------------------------------------------------
# Grafana host port. Default 3000. Change if a host port collides.
GRAFANA_PORT=3000

# Grafana admin credentials. Change the password before exposing publicly.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
