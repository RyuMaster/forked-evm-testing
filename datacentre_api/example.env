# .env

# Root path if served at a path other than /
ROOT_PATH=/api

# MySQL Database configuration
MYSQL_HOST=xxxx
MYSQL_PORT=xxxx
MYSQL_USER=xxxx
MYSQL_PASSWORD=xxxx
MYSQL_DB=xxxx

MYSQL_ARCHIVAL_HOST=xxx
MYSQL_ARCHIVAL_PORT=xxx
MYSQL_ARCHIVAL_USER=xxx
MYSQL_ARCHIVAL_PASSWORD=xxx
MYSQL_ARCHIVAL_DB=xxxx

# Game ID to use for activity and user tracking (use sv for production
# and svt for test).
GAME_ID=sv

# The Graph Postgres database
GRAPH_POSTGRES_HOST=xxx
GRAPH_POSTGRES_PORT=xxx
GRAPH_POSTGRES_USER=xxx
GRAPH_POSTGRES_PASSWORD=xxxx
GRAPH_POSTGRES_DB=xxx
# IPFS hash of the subgraph deployment (schema name looked up at startup)
# for the xaya-stats subgraph.
GRAPH_SUBGRAPH_STATS=QmXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# IPFS hash of the sv-subgraph
GRAPH_SUBGRAPH_SV=QmXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# For userconfig database
USERCONFIG_HOST=10.0.5.215
USERCONFIG_PORT=3306
USERCONFIG_USER=root
USERCONFIG_PASS=xx
USERCONFIG_DB=userconfig

# Default image URL
DEFAULT_PROFILE_PIC_URL=https://downloads.soccerverse.com/default_profile.jpg

# Output folder for precomputed data dump files written by the datacentre_updater
# DataDumpUpdater (share orders, leagues, earnings, packs, etc.).
# Leave unset or empty to disable the /dumps/* endpoints (they will return 503).
# DUMP_OUTPUT_FOLDER=/var/data/dumps

#Redis
REDIS_HOST=10.0.5.215
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# The Graph Subgraph URL for sv-subgraph.
GRAPH_SUBGRAPH_SV_URL=https://graph.soccerverse.com/subgraphs/id/QmQ9UjsDFwef2KUkLPTZuxHfHXjBE6JTAiueEjcuLFcMFP
